# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

GEMINI_DATABASE_URL=

# SENTINEL_CRON_INTERVAL: Interval for the Sentinel agent to fetch intelligence.
# Default is every 30 minutes.
SENTINEL_CRON_INTERVAL="*/30 * * * *"

CONNECTOR_CRON_INTERVAL=0 */6 * * *
PORT=3000

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
INBOX_CRON_INTERVAL=0 */2 * * *
SENTINEL_LEGAL_CRON_INTERVAL=0 */1 * * *
ENVOY_JWT_SECRET=super_secret_dev_key
BCRYPT_ROUNDS=12
DIPLOMAT_EMAIL=
SEND_QUEUE_CRON_INTERVAL="*/5 * * * *"
